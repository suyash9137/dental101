import Link from 'next/link';
import { Fragment, useEffect, useState } from 'react';
import { motion, Variants } from 'framer-motion';

interface HeaderProps {
  scrolled?: boolean;
}

// Variants for animations
const navLinkHover: Variants = {
  initial: { y: 0, scale: 1 },
  whileTap: { y: -2, scale: 0.98 },
  whileHover: { y: -1, scale: 1.02 },
  transition: { type: "spring", stiffness: 300, damping: 20 }
};

const menuItemHover: Variants = {
  initial: { x: 0 },
  whileTap: { x: -2 },
  whileHover: { x: 2 },
  transition: { type: "spring", stiffness: 300, damping: 20 }
};

const buttonPulse: Variants = {
  initial: { scale: 1 },
  whileTap: { scale: 0.95 },
  whileHover: { scale: 1.03 },
  transition: { type: "spring", stiffness: 300, damping: 20 }
};

export default function Header({ scrolled = false }: HeaderProps) {
  const [isMenuOpen, setIsMenuOpen] = useState(false);

  useEffect(() => {
    if (isMenuOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  }, [isMenuOpen]);

  const toggleMenu = () => setIsMenuOpen(!isMenuOpen);

  return (
    <Fragment>
      {/* Desktop Header */}
      <header
        className={`fixed top-0 w-full z-50 transition-all duration-500 ease-out ${
          scrolled ? 'bg-surface/95 shadow-md backdrop-blur-lg' : 'bg-surface/90 backdrop-blur-md'
        }`}
      >
        <div className="flex justify-between items-center px-4 md:px-6 max-w-container-max mx-auto h-20">
          {/* Brand */}
          <Link href="/" className="flex items-center gap-2">
            <motion.span
              whileHover={navLinkHover}
              whileTap={{ scale: 0.95 }}
              className="material-symbols-outlined"
              style={{ fontVariationSettings: "'FILL' 1" }}
            >
              medical_services
            </motion.span>
            <span className="font-headline-sm text-headline-sm font-bold tracking-tight text-gradient-primary">
              SmileCraft Dental
            </span>
          </Link>

          {/* Navigation */}
          <nav className="hidden md:flex gap-8 items-center h-full">
            <Link
              href="/"
              whileHover={navLinkHover}
              whileTap={{ scale: 0.95 }}
              className="font-label-bold text-label-bold text-on-surface-variant hover:text-primary hover:bg-primary/5 transition-colors duration-300 h-full flex items-center px-2"
            >
              Home
            </Link>
            <Link
              href="/services"
              whileHover={navLinkHover}
              whileTap={{ scale: 0.95 }}
              className="font-label-bold text-label-bold text-on-surface-variant border-b-2 border-primary-transparent hover:border-primary pb-1 transition-all duration-300 h-full flex items-center px-2"
            >
              Services
            </Link>
            <Link
              href="/specialists"
              whileHover={navLinkHover}
              whileTap={{ scale: 0.95 }}
              className="font-label-bold text-label-bold text-on-surface-variant hover:text-primary hover:bg-primary/5 transition-colors duration-300 h-full flex items-center px-2"
            >
              Specialists
            </Link>
            <Link
              href="/gallery"
              whileHover={navLinkHover}
              whileTap={{ scale: 0.95 }}
              className="font-label-bold text-label-bold text-on-surface-variant hover:text-primary hover:bg-primary/5 transition-colors duration-300 h-full flex items-center px-2"
            >
              Gallery
            </Link>
          </nav>

          {/* Actions */}
          <div className="flex items-center gap-4">
            <Link
              href="/book-appointment"
              whileHover={buttonPulse}
              whileTap={{ scale: 0.95 }}
              className="hidden md:block font-label-bold text-label-bold bg-primary text-on-primary rounded-full px-6 py-2 hover:bg-primary-container transition-colors duration-300 shadow-md hover:shadow-lg"
            >
              Book Now
            </Link>
            <button
              aria-label="Open menu"
              whileHover={navLinkHover}
              whileTap={{ scale: 0.95 }}
              className={`md:hidden text-on-surface p-2 transition-transform duration-300`}
              onClick={toggleMenu}
            >
              <span className="material-symbols-outlined text-2xl">menu</span>
            </button>
          </div>
        </div>
      </header>

      {/* Mobile Drawer */}
      <motion.nav
        initial={{ x: "-100%" }}
        animate={isMenuOpen ? "0%" : "-100%"}
        exit={{ x: "-100%" }}
        transition={{ type: "spring", stiffness: 300, damping: 20 }}
        className={`fixed inset-y-0 left-0 w-80 z-[60] bg-surface dark:bg-surface-dim shadow-xl rounded-r-full md:hidden flex flex-col`}
      >
        <div className="p-6 border-b border-surface-container-low flex justify-between items-center">
          <span className="font-headline-sm text-headline-sm text-primary">Patient Portal</span>
          <button
            className="text-on-surface-variant p-2 rounded-full hover:bg-surface-container-high transition-colors duration-300 hover-lift-medium"
            onClick={toggleMenu}
          >
            <span className="material-symbols-outlined">close</span>
          </button>
        </div>
        <nav className="flex-col">
patch applied successfully
